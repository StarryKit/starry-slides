{
  "name": "@starry-slide/editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./dist/index.css"
    }
  },
  "scripts": {
    "dev": "pnpm run dev:js & pnpm run dev:css",
    "dev:js": "tsup src/index.tsx --format esm --dts --watch",
    "dev:css": "tailwindcss -i src/styles/index.css -o dist/index.css --watch",
    "build": "pnpm run build:js && pnpm run build:css",
    "build:js": "tsup src/index.tsx --format esm --dts",
    "build:css": "tailwindcss -i src/styles/index.css -o dist/index.css --minify"
  },
  "dependencies": {
    "@starry-slide/core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.11",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/react": "^19.1.2",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
