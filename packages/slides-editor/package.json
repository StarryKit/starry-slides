{
  "name": "@starrykit/slides-editor",
  "version": "0.1.30",
  "description": "Embeddable React editor UI for Starry Slides — host-driven through props and callbacks.",
  "license": "MIT",
  "homepage": "https://github.com/StarryKit/starry-slides#readme",
  "bugs": {
    "url": "https://github.com/StarryKit/starry-slides/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StarryKit/starry-slides",
    "directory": "packages/slides-editor"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsup src/index.tsx --format esm --external react --external react-dom"
  },
  "dependencies": {
    "@starrykit/slides-core": "0.1.30",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.11",
    "lucide-react": "^1.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "radix-ui": "^1.4.3",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
