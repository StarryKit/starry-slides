{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@starrykit/slides-core": ["packages/slides-core/src/index.ts"],
      "@starrykit/slides-editor": ["packages/slides-editor/src/index.tsx"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true
  }
}
