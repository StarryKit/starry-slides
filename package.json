{
  "name": "starry-slides",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "node scripts/dev-with-url.mjs",
    "build": "pnpm -r build",
    "generate:slides": "node skills/html-slides-generator/generate-slides.mjs",
    "prepare:regression-deck": "node testing/regression-deck/prepare-regression-deck.mjs",
    "slides:protocol:create-style-pack": "node skills/slides-protocol/tools/create-style-pack.mjs",
    "slides:protocol:validate": "node skills/slides-protocol/tools/validate-slides.mjs",
    "slides:protocol:annotate": "node skills/slides-protocol/tools/annotate-slides.mjs",
    "slides:protocol:manifest": "node skills/slides-protocol/tools/build-manifest.mjs",
    "test:e2e:prepare": "pnpm prepare:regression-deck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r --if-present test",
    "test:e2e:serve": "pnpm test:e2e:prepare && pnpm build && pnpm --filter web exec vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "playwright test",
    "verify": "pnpm lint && pnpm test && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.2",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
